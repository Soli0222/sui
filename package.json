{
  "name": "sui",
  "version": "1.7.1",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @sui/backend --filter @sui/frontend dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "version:check": "./scripts/check-versions.sh",
    "version:sync": "./scripts/sync-versions.sh",
    "upgrade:latest": "pnpm -r upgrade --latest && pnpm upgrade --latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sui/db": "workspace:*",
    "@sui/shared": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
