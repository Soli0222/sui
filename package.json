{
  "name": "sui",
  "version": "1.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "ignoredBuiltDependencies": [
      "@prisma/client"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @sui/backend --filter @sui/frontend dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "upgrade:latest": "pnpm -r upgrade --latest && pnpm upgrade --latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sui/db": "workspace:*",
    "@sui/shared": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "prisma": "^7.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  }
}
