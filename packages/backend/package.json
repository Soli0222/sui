{
  "name": "@sui/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsup",
    "test": "vitest run",
    "test:integration": "DATABASE_URL=postgresql://sui_test:sui_test@localhost:5555/sui_test vitest run --config vitest.integration.config.ts",
    "test:db:up": "docker compose -f ../../compose_db.yaml up -d --wait",
    "test:db:down": "docker compose -f ../../compose_db.yaml down",
    "test:db:migrate": "DATABASE_URL=postgresql://sui_test:sui_test@localhost:5555/sui_test prisma migrate deploy",
    "typecheck": "tsc --project tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.5.0",
    "@sui/shared": "workspace:*",
    "hono": "^4.7.5",
    "prisma": "^6.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
