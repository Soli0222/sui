{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
  ],
  timezone: 'Asia/Tokyo',
  prConcurrentLimit: 10,
  prHourlyLimit: 20,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Pin Docker image digests and GitHub Action digests for reproducibility",
      "matchManagers": ["dockerfile", "docker-compose", "github-actions"],
      "pinDigests": false,
    },
    {
      "description": "Require review for major version updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "reviewers": ["Soli0222"],
    },
  ],
}
